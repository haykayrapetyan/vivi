# Database
DATABASE_URL=postgresql://user@localhost:5432/vivi

# Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Resend
RESEND_API_KEY=
EMAIL_FROM=Vivi <onboarding@resend.dev>

# Storage: Cloudflare R2 (S3-compatible) — required for video
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Cloudflare agent worker (agent-worker/, Agents SDK on Durable Objects).
# Dev: run `pnpm dev:agent` alongside `pnpm dev`; without it, candidate
# screening falls back to inline execution (no kickoff/heartbeat though).
# AGENT_GATEWAY_SECRET must match the worker's secret (.dev.vars locally,
# `wrangler secret put` in prod). Generate with: openssl rand -hex 16
AGENT_WORKER_URL=http://localhost:8787
AGENT_GATEWAY_SECRET=
